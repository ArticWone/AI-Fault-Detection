# Copy this to /srv/smi-ai/config/cameras.env on the brain node.
# Do not commit the real file because it contains camera credentials.

SMI_CAMERA_USER="smi"
SMI_CAMERA_PASSWORD="change-me"

# Space-separated camera list. Use stable DHCP reservations or static IPs.
# Format for each item: camera_id=ip_address
SMI_CAMERAS="camera1=192.168.0.25"

# Optional browser-facing admin URLs. Use a tunnel URL when the operator PC
# cannot reach the camera subnet directly, for example camera1=http://127.0.0.1:8085/
SMI_CAMERA_ADMIN_URLS="camera1=http://192.168.0.25/"

# Reolink standalone RTSP path. Older RLC-522 firmware may require h264Preview_01_main.
SMI_CAMERA_RTSP_PORT="554"
SMI_CAMERA_STREAM="main"
SMI_CAMERA_RTSP_PATH_PREFIX="h264Preview_01_"

# Rotating recorder defaults.
SMI_VIDEO_ROOT="/srv/smi-ai/video"
SMI_VIDEO_BUDGET_GB="400"
SMI_VIDEO_SEGMENT_SECONDS="300"
